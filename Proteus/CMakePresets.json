{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-x64-debug",
      "displayName": "VS 2026 x64 Debug",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "PROTEUS_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "vs2026-x64-debug-tests",
      "displayName": "VS 2026 x64 Debug (Tests ON)",
      "inherits": "vs2026-x64-debug",
      "cacheVariables": {
        "PROTEUS_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "vs2026-x64-release",
      "displayName": "VS 2026 x64 Release",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PROTEUS_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "vs2026-x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-debug-tests",
      "configurePreset": "vs2026-x64-debug-tests",
      "configuration": "Debug"
    },
    {
      "name": "build-release",
      "configurePreset": "vs2026-x64-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-debug",
      "configurePreset": "vs2026-x64-debug-tests",
      "configuration": "Debug",
      "output": { "outputOnFailure": true },
      "filter": {
        "exclude": { "label": "timing" }
      }
    },
    {
      "name": "test-debug-timing",
      "configurePreset": "vs2026-x64-debug-tests",
      "configuration": "Debug",
      "output": { "verbosity": "verbose" },
      "filter": {
        "include": { "label": "timing" }
      }
    }
  ]
}