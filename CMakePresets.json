{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "Ninja Debug x64",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build-ninja",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "PROTEUS_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "windows-x64-debug-tests",
      "displayName": "Ninja Debug x64 (Tests ON)",
      "inherits": "windows-x64-debug",
      "cacheVariables": {
        "PROTEUS_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Ninja Release x64",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build-ninja",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "PROTEUS_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "windows-x64-release-tests",
      "displayName": "Ninja Release x64 (Tests ON)",
      "inherits": "windows-x64-release",
      "cacheVariables": {
        "PROTEUS_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-debug",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-debug-tests",
      "configurePreset": "windows-x64-debug-tests",
      "configuration": "Debug"
    },
    {
      "name": "build-windows-release",
      "configurePreset": "windows-x64-release",
      "configuration": "Release"
    },
    {
      "name": "build-windows-release-tests",
      "configurePreset": "windows-x64-release-tests",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "test-windows-debug",
      "configurePreset": "windows-x64-debug-tests",
      "configuration": "Debug",
      "output": { "outputOnFailure": true },
      "filter": {
        "exclude": { "label": "timing" }
      }
    },
    {
      "name": "test-windows-debug-timing",
      "configurePreset": "windows-x64-debug-tests",
      "configuration": "Debug",
      "output": { "verbosity": "verbose" },
      "filter": {
        "include": { "label": "timing" }
      }
    },
    {
      "name": "test-windows-release",
      "configurePreset": "windows-x64-release-tests",
      "configuration": "Release",
      "output": { "outputOnFailure": true },
      "filter": {
        "exclude": { "label": "timing" }
      }
    },
    {
      "name": "test-windows-release-timing",
      "configurePreset": "windows-x64-release-tests",
      "configuration": "Release",
      "output": { "verbosity": "verbose" },
      "filter": {
        "include": { "label": "timing" }
      }
    }
  ]
}